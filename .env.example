# ================================
# ts-panel 环境变量配置示例
# 复制为 .env 并填写真实值
# ================================

# 服务器公网 IP
PUBLIC_IP=1.2.3.4

# 管理后台 Token（请使用强密码）
ADMIN_TOKEN=your-strong-admin-token-here

# Go 代理地址
GOPROXY=https://goproxy.cn,direct

# HTTP 端口
HTTP_PORT=8080
PANEL_HTTP_PORT=80

# 语音 UDP 端口池（公网开放）
PORT_MIN=20000
PORT_MAX=20999

# ServerQuery TCP 端口池（仅本机）
QUERY_PORT_MIN=21000
QUERY_PORT_MAX=21999

# 容器资源限制默认值
DEFAULT_CPU=0.5
DEFAULT_MEMORY=512m
DEFAULT_PIDS=200

# 重试配置
CREATE_RETRY=2
SECRETS_RETRY=10
LOG_TAIL=300

# 数据根目录
DATA_ROOT=/data

# SQLite 数据库路径（测试模式时使用）
DB_PATH=/data/db/app.db

# ================================
# 数据库配置
# ================================

# 测试模式：设置为 true 时使用 SQLite（适合快速测试）
TEST_MODE=false

# 数据库类型：mysql 或 sqlite（默认 mysql）
DB_TYPE=mysql

# MySQL 连接配置（仅在 DB_TYPE=mysql 且 TEST_MODE=false 时生效）
# 若留空或未设置，将自动启动内置 MySQL 容器
DB_HOST=mysql
DB_PORT=3306
DB_USER=tspanel
DB_PASSWORD=
DB_NAME=tspanel

# MySQL Root 密码（仅用于内置 MySQL 容器）
MYSQL_ROOT_PASSWORD=root_secret
