# ================================
# ts-panel 环境变量配置示例
# 复制为 .env 并填写真实值
# ================================

# 服务器公网 IP
PUBLIC_IP=1.2.3.4

# 管理后台 Token（请使用强密码）
ADMIN_TOKEN=your-strong-admin-token-here

# HTTP 端口
HTTP_PORT=8080

# 语音 UDP 端口池（公网开放）
PORT_MIN=20000
PORT_MAX=20999

# ServerQuery TCP 端口池（仅本机）
QUERY_PORT_MIN=21000
QUERY_PORT_MAX=21999

# 容器资源限制默认值
DEFAULT_CPU=0.5
DEFAULT_MEMORY=512m
DEFAULT_PIDS=200

# 重试配置
CREATE_RETRY=2
SECRETS_RETRY=10
LOG_TAIL=300

# 数据根目录
DATA_ROOT=/data

# SQLite 数据库路径
DB_PATH=/data/db/app.db
